# ====== BTC Global Elite Scalper V6 — Environment Variables ======
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# --- Mode: "testnet" or "production" ---
MODE=testnet

# --- Delta Exchange India API ---
# Testnet: https://cdn-ind.testnet.deltaex.org
# Production: https://api.india.delta.exchange
DELTA_API_KEY=your_delta_api_key_here
DELTA_API_SECRET=your_delta_api_secret_here
DELTA_BASE_URL=https://cdn-ind.testnet.deltaex.org

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Supabase PostgreSQL ---
DATABASE_URL=postgresql://postgres:your_password@db.your_project.supabase.co:5432/postgres

# --- Finnhub API (Free Tier) ---
FINNHUB_API_KEY=your_finnhub_api_key_here

# --- Render Keep-Alive ---
RENDER_APP_URL=https://your-app-name.onrender.com
