# ====== HA + Chandelier Exit + LSMA Bot — Environment Variables ======
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git!

# --- Mode: "testnet" or "production" ---
MODE=production

# --- Delta Exchange India API ---
# Testnet: https://cdn-ind.testnet.deltaex.org
# Production: https://api.india.delta.exchange
DELTA_API_KEY=your_api_key_here
DELTA_API_SECRET=your_api_secret_here
DELTA_BASE_URL=https://api.india.delta.exchange

# --- Telegram Bot ---
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Supabase PostgreSQL ---
# Get from Supabase Dashboard > Settings > Database > Connection String
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Finnhub API (Free Tier) ---
# Sign up at https://finnhub.io/ for free API key
FINNHUB_API_KEY=your_finnhub_key

# --- Render Keep-Alive ---
# Set this to your Render app URL after deployment
RENDER_APP_URL=https://ha-ce-lsma-bot.onrender.com
